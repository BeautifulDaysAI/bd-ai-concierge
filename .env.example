# ========================================
# Beautiful Days AI Concierge - 環境変数
# ========================================
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local

# ----------------------------------------
# LINE Messaging API
# ----------------------------------------
# 取得: https://developers.line.biz/console/
# Channel basic settings → Channel secret
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ----------------------------------------
# Anthropic Claude API
# ----------------------------------------
# 取得: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# 使用モデル（指定がなければデフォルト）
ANTHROPIC_MODEL=claude-sonnet-4-5

# ----------------------------------------
# Supabase
# ----------------------------------------
# 取得: https://supabase.com/dashboard/project/_/settings/api
# 必ず東京リージョン (ap-northeast-1) で作成すること
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxx

# service_role キーは絶対にクライアント側で使わない
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxx

# ----------------------------------------
# アプリ設定
# ----------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ----------------------------------------
# 管理者通知（オプション）
# ----------------------------------------
# FPへの通知連携用（Slack Webhook URL等）
ADMIN_WEBHOOK_URL=

# 朝のチェック係への通知先（Slack User ID等）
MORNING_REVIEWER_NOTIFY=

# ----------------------------------------
# Stripe（Phase 2で使用）
# ----------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
